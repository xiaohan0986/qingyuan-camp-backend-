# 青园营地 - .gitignore

# 环境配置文件（包含敏感信息）
.env

# 日志文件
*.log
logs/

# 缓存文件
cache/
*.cache

# 临时文件
tmp/
temp/
*.tmp

# IDE 配置
.vscode/
.idea/
.hbuilderx/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 备份文件
*.bak
*.backup
*_backup_*/

# 上传文件
uploads/
attachments/

# 测试页面（未经审核不上代码库）
111ceshi/

# Composer
vendor/

# Node.js
node_modules/
package-lock.json

# 测试文件
tests/coverage/
.phpunit.result.cache
